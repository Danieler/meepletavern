generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum GameStatus {
  draft
  published
  archived
}

enum TaxonomyType {
  category
  mechanic
  theme
}

enum GameImageStatus {
  verified
  missing
  placeholder
  needs_review
}

model Game {
  id             String     @id @default(cuid())
  name           String
  slug           String     @unique
  status         GameStatus @default(draft)
  imageUrl       String?
  coverImageUrl  String?
  coverImageAlt  String     @default("")
  imageSourceName String?
  imageSourceUrl String?
  imageLicenseNote String?
  imageStatus    GameImageStatus @default(missing)
  description    String?
  review         String?
  shortSummary   String?
  pros           String[]   @default([])
  cons           String[]   @default([])
  bestFor        String?
  notFor         String?
  minPlayers     Int?
  maxPlayers     Int?
  playtime       String?
  age            String?
  complexity     String?
  categories     String[]   @default([])
  mechanics      String[]   @default([])
  themes         String[]   @default([])
  similarGames   String[]   @default([])
  faqs           Json?
  seoTitle       String?
  seoDescription String?
  buyUrl         String?
  sources        Json?
  createdByAi    Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  publishedAt    DateTime?

  @@index([status])
  @@index([createdAt])
}

model TaxonomyTerm {
  id        String       @id @default(cuid())
  type      TaxonomyType
  name      String
  slug      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([type, slug])
  @@index([type])
}
