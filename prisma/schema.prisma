generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum GameStatus {
  draft
  review
  published
  archived
}

enum GameCandidateStatus {
  pending
  needs_review
  approved
  rejected
  converted
}

enum EditorialFlag {
  possible_duplicate
  missing_players
  missing_playtime
  missing_age
  image_not_allowed
  low_confidence
  needs_permission
}

enum MediaAssetType {
  cover
  box
  component
  placeholder
}

enum MediaAssetStatus {
  candidate
  approved
  rejected
}

enum MediaAssetUsage {
  public
  admin_only
  purchase_only
}

enum TaxonomyType {
  category
  mechanic
  theme
}

enum GameImageStatus {
  verified
  missing
  placeholder
  needs_review
}

enum GameImportProposalStatus {
  pending
  applied
  rejected
}

model Game {
  id                    String          @id @default(cuid())
  name                  String
  slug                  String          @unique
  status                GameStatus      @default(draft)
  title                 String          @default("")
  originalTitle         String?
  year                  Int?
  players               Json            @default("{}")
  imageUrl              String?
  coverImageUrl         String?
  coverImageAlt         String          @default("")
  imageSourceName       String?
  imageSourceUrl        String?
  imageLicenseNote      String?
  imageStatus           GameImageStatus @default(missing)
  description           String?
  review                String?
  shortSummary          String?
  shortDescription      String?
  quickVerdict          String?
  pros                  String[]        @default([])
  cons                  String[]        @default([])
  bestFor               String?
  notFor                String?
  minPlayers            Int?
  maxPlayers            Int?
  playtime              String?
  age                   String?
  minAge                Int?
  complexity            String?
  difficulty            String?
  categories            String[]        @default([])
  mechanics             String[]        @default([])
  themes                String[]        @default([])
  publisher             String?
  spanishPublisher      String?
  similarGames          String[]        @default([])
  faqs                  Json?
  faq                   Json?
  seoTitle              String?
  seoDescription        String?
  buyUrl                String?
  ratings               Json            @default("{}")
  sources               Json?
  sourceIds             String[]        @default([])
  primaryImageId        String?
  imageFallbackAccepted Boolean         @default(false)
  createdByAi           Boolean         @default(false)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  publishedAt           DateTime?
  mediaAssets           MediaAsset[]
  candidates            GameCandidate[]
  libraryEntries        UserLibraryGame[]
  reviews               Review[]
  comments              GameComment[]
  importProposals       GameImportProposal[]

  @@index([status])
  @@index([createdAt])
}

model GameImportProposal {
  id               String                 @id @default(cuid())
  gameId           String
  game             Game                   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  provider         String
  status           GameImportProposalStatus @default(pending)
  query            String
  rawSearchResults Json
  extractedFields  Json
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([gameId, status])
  @@index([createdAt])
}

model User {
  id          String   @id @default(cuid())
  authUserId  String   @unique
  email       String   @unique
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  library     UserLibraryGame[]
  reviews     Review[]
  comments    GameComment[]
}

model Review {
  id             String   @id @default(cuid())
  gameId          String
  userId          String?
  authorName      String
  title           String
  slug            String   @unique
  summary         String
  body            String
  createdByAdmin  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  publishedAt     DateTime @default(now())
  game            Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([gameId, publishedAt])
  @@index([userId, createdAt])
  @@index([publishedAt])
}

model GameComment {
  id        String   @id @default(cuid())
  gameId    String
  userId    String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([gameId, updatedAt])
  @@index([userId, updatedAt])
}

model UserLibraryGame {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([userId, createdAt])
  @@index([gameId])
}

model Source {
  id         String          @id @default(cuid())
  name       String
  baseUrl    String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  candidates GameCandidate[]
  mediaAssets MediaAsset[]

  @@index([createdAt])
}

model GameCandidate {
  id                   String              @id @default(cuid())
  sourceId             String
  source               Source              @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceUrl            String
  title                String
  originalTitle        String?
  gameId               String?
  game                 Game?               @relation(fields: [gameId], references: [id], onDelete: SetNull)
  metadata             Json                @default("{}")
  extractedDescription String?
  candidateImages      Json                @default("[]")
  aiDraft              Json?
  aiGenerated          Boolean             @default(false)
  aiReviewed           Boolean             @default(false)
  confidence           Float               @default(0)
  status               GameCandidateStatus @default(pending)
  flags                EditorialFlag[]     @default([])
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  mediaAssets          MediaAsset[]

  @@index([sourceId])
  @@index([gameId])
  @@index([status])
  @@index([createdAt])
}

model MediaAsset {
  id          String           @id @default(cuid())
  gameId      String?
  game        Game?            @relation(fields: [gameId], references: [id], onDelete: SetNull)
  candidateId String?
  candidate   GameCandidate?   @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  sourceId    String?
  source      Source?          @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  url         String
  localPath   String?
  type        MediaAssetType
  status      MediaAssetStatus @default(candidate)
  usage       MediaAssetUsage  @default(admin_only)
  attribution String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([gameId])
  @@index([candidateId])
  @@index([sourceId])
  @@index([status])
  @@index([usage])
}

model TaxonomyTerm {
  id        String       @id @default(cuid())
  type      TaxonomyType
  name      String
  slug      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([type, slug])
  @@index([type])
}
